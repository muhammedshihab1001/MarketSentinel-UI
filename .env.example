# ─── Backend API Server ───────────────────────────────────────
# Development: leave unset (Vite dev proxy forwards /api → localhost:8000)
# Production:  set to your backend URL — e.g. https://api.marketsentinel.io
# VITE_API_BASE_URL=https://api.marketsentinel.io

# ─── Application Name ─────────────────────────────────────────
VITE_APP_NAME="MarketSentinel Quant Dashboard"

# ─── Environment ──────────────────────────────────────────────
# Values: development | staging | production
VITE_ENV=production

# ─── API Timeout (ms) ─────────────────────────────────────────
VITE_API_TIMEOUT=15000

# ─── Grafana URL (optional — for Metrics page link) ───────────
# Development: leave unset (defaults to localhost:3000)
# Production:  set to your Grafana instance
# VITE_GRAFANA_URL=https://grafana.marketsentinel.io
VITE_API_BASE_URL=
VITE_APP_NAME="MarketSentinel Quant Dashboard"