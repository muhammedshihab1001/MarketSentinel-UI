# ── DEVELOPMENT: DEV SERVER PROXY ─────────────────────────────
# Set this to your backend server URL for local development.
# 
# 👉 SECURITY NOTE (No VITE_ prefix)
# Because it lacks the VITE_ prefix, this variable is NEVER embedded
# into the compiled JavaScript. It is kept securely on the build machine
# and used only by vite.config.ts to configure the dev server proxy.
#
API_PROXY_TARGET=https://api.your-domain.com


# ── PRODUCTION: CLIENT RUNTIME ────────────────────────────────
# In production (e.g., Vercel), there is no Vite proxy. Instead, the 
# browser hits the backend directly. Set this URL for production.
# 
# 👉 SECURITY NOTE (Has VITE_ prefix)
# Because it starts with VITE_, this WILL be directly embedded into the
# frontend JavaScript and is visible in the browser. 
# Do not place secrets here!
#
# 👉 DEVELOPMENT RULE: LEAVE THIS COMMENTED OUT
# If you uncomment this locally, the app will bypass the dev proxy.
#
# VITE_API_BASE_URL=https://api.your-domain.com


# ── APPLICATION SETTINGS ──────────────────────────────────────
VITE_APP_NAME="MarketSentinel Quant Dashboard"

# Values: development | staging | production
VITE_ENV=production
VITE_API_TIMEOUT=15000

# Grafana dashboard URL — shown as a button on the Metrics page.
# Leave commented to hide the button.
# VITE_GRAFANA_URL=https://grafana.your-domain.com