# ─── Dependencies ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build Output ─────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ─── Environment Files ────────────────────────────────────────
